{
  "name": "fraud-team",
  "description": "Realistic YC-fintech fraud pipeline \u2014 5 event types (Txn, Login, Signup, CardAdd, Refund), 5 group_by axes (user, card, device, ip, merchant), 90 features exercising all 55 Beava ops. Mirrors industry feature-catalogues from Stripe Radar, Adyen RevenueProtect, Shopify, Tecton, Feldera. See .planning/research/fraud-feature-catalogue.md for source attribution.",
  "register": {
    "nodes": [
      {
        "kind": "event",
        "name": "Txn",
        "schema": {
          "fields": {
            "event_time": "i64",
            "user_id": "str",
            "card_fp": "str",
            "device_id": "str",
            "ip_address": "str",
            "ip_block": "str",
            "merchant_id": "str",
            "amount": "f64",
            "currency": "str",
            "mcc": "str",
            "card_country": "str",
            "ip_country": "str",
            "billing_country": "str",
            "lat": "f64",
            "lon": "f64",
            "declined": "i64",
            "is_3ds": "i64",
            "card_funding": "str",
            "ssn_hash": "str"
          },
          "optional_fields": []
        }
      },
      {
        "kind": "event",
        "name": "Login",
        "schema": {
          "fields": {
            "event_time": "i64",
            "user_id": "str",
