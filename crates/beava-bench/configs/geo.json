{
  "name": "geo",
  "description": "Phase 11 geo+buffer shape. Exercises geo_velocity + geo_distance + most_recent_n. Plan 19.2-06: unique_cells removed from catalogue; geo_distance used instead for cardinality-free geo coverage.",
  "register": {
    "nodes": [
      {
        "kind": "event",
        "name": "GeoTxn",
        "schema": {
          "fields": {
            "event_time": "i64",
            "user_id": "str",
            "lat": "f64",
            "lon": "f64",
            "amount": "f64"
          },
          "optional_fields": []
        },
        "event_time_field": "event_time"
      },
      {
        "kind": "derivation",
        "name": "GeoTxnAgg",
        "output_kind": "table",
        "upstreams": ["GeoTxn"],
        "ops": [
          {
            "op": "group_by",
            "keys": ["user_id"],
            "agg": {
              "kmh": { "op": "geo_velocity", "params": {"lat": "lat", "lon": "lon"} },
              "path_km": { "op": "geo_distance", "params": {"lat": "lat", "lon": "lon"} },
              "last5": { "op": "most_recent_n", "params": {"field": "amount", "n": 5} }
            }
          }
        ],
        "schema": {
          "fields": {
            "user_id": "str",
            "kmh": "f64",
            "path_km": "f64",
            "last5": "str"
          },
          "optional_fields": []
        },
        "table_primary_key": ["user_id"]
      }
    ]
  },
  "event_name": "GeoTxn",
  "features": ["kmh", "path_km", "last5"],
  "key_field": "user_id",
  "extra_fields": {
    "lat": "f64",
    "lon": "f64",
    "amount": "f64"
  }
}
