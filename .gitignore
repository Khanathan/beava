# Rust
/target
**/target/
**/*.rs.bk
!/Cargo.lock
# proptest regression files (generated at test time; not committed per proptest convention)
proptest-regressions/

# Python
__pycache__/
*.pyc
*.pyo
.pytest_cache/
*.egg-info/
dist/
build/
*.whl
.venv/
venv/

# Beava-specific
.thoughts/
deck/
*.snapshot*
events/
beava.snapshot*
# Runtime WAL/snapshot dirs that tests may create in the repo root
**/beava-wal/
**/beava-snapshots/

# Marketing / pitch artifacts (not part of the OSS tree)
deck-*.html
deck-*.pdf
*_Deck.pdf
Tally_VAS2026_Deck.pdf
branding*.png
beaver*.png
!site/assets/branding*.png
2026-*-outreach-*.md

# IDE
.vscode/
.idea/
*.swp
*.swo
*~

# Environment
.env
.env.*

# Benchmark results
benchmark/**/results/

# OS
.DS_Store
Thumbs.db

# Claude Code: ignore everything except the shipped /beava skill
.claude/*
!.claude/skills/
.claude/skills/*
!.claude/skills/beava/

# MCP server config (personal, points to local gbrain instance)
.mcp.json
.gstack/

# Beava website build artifacts
beava-website/node_modules/
render-docs-warnings.txt
beava-website/link-audit-report.txt

# IDE configs (additional)
.cursor/

# OS metadata (additional)
._*
Desktop.ini

# Editor backups / generic temp
*.bak
*.tmp
.cache/

# Logs
*.log
tmp/

# Python type-check + lint caches
.mypy_cache/
.ruff_cache/

# JS/TS (global; sdk/typescript also has its own .gitignore)
node_modules/
*.tsbuildinfo

# Go (defensive — Go SDK in Phase 13.6 roadmap)
vendor/
*.test

# Coverage / profiling
.coverage
coverage.xml
htmlcov/
*.lcov
flamegraph.svg
*.trace/
*.trace

# Local secrets (additional)
*.pem
*.key
secrets/

# Beava runtime data dir (post-12.9 convention)
.beava/
