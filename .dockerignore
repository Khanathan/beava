# Build artifacts + VCS — never send to Docker build context
target/
.git/
.gitignore

# Test + planning dirs (zero runtime value; speeds up COPY and avoids cache busting)
tests/
.planning/
.claude/
.agents/

# Docs, examples, decks (not needed to compile the binary)
docs/
examples/
benchmark/
deck/
launch/
site/
*.pdf
*.md

# But re-include Cargo manifests + source (required for cargo chef prepare)
!Cargo.toml
!Cargo.lock
!src/
!benches/
!python/

# Local data snapshots from dev runs
beava.snapshot.*
events/
data/
demo.py
*.log

# Docker files themselves (no need to embed)
docker-compose.yml
.dockerignore
