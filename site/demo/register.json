{
  "nodes": [
    {
      "kind": "event",
      "name": "Transaction",
      "schema": {
        "fields": {
          "event_time": "i64",
          "user_id": "str",
          "amount": "f64",
          "status": "str",
          "merchant": "str"
        },
        "optional_fields": []
      },
      "event_time_field": "event_time"
    },
    {
      "kind": "derivation",
      "name": "UserStats",
      "output_kind": "table",
      "upstreams": ["Transaction"],
      "ops": [
        {
          "op": "group_by",
          "keys": ["user_id"],
          "agg": {
            "tx_count_5m":      {"op": "count",    "params": {"window": "5m"}},
            "tx_count_total":   {"op": "count",    "params": {}},
            "tx_sum_5m":        {"op": "sum",      "params": {"field": "amount", "window": "5m"}},
            "tx_avg_5m":        {"op": "avg",      "params": {"field": "amount", "window": "5m"}},
            "tx_min_5m":        {"op": "min",      "params": {"field": "amount", "window": "5m"}},
            "tx_max_5m":        {"op": "max",      "params": {"field": "amount", "window": "5m"}},
            "tx_variance_5m":   {"op": "variance", "params": {"field": "amount", "window": "5m"}},
            "tx_stddev_5m":     {"op": "stddev",   "params": {"field": "amount", "window": "5m"}},
            "decline_ratio_5m": {"op": "ratio",    "params": {"where": {"col": "status", "op": "eq", "value": "decline"}, "window": "5m"}}
          }
        }
      ],
      "schema": {
        "fields": {
          "user_id":          "str",
          "tx_count_5m":      "i64",
          "tx_count_total":   "i64",
          "tx_sum_5m":        "f64",
          "tx_avg_5m":        "f64",
          "tx_min_5m":        "f64",
          "tx_max_5m":        "f64",
          "tx_variance_5m":   "f64",
          "tx_stddev_5m":     "f64",
          "decline_ratio_5m": "f64"
        },
        "optional_fields": []
      },
      "table_primary_key": ["user_id"]
    }
  ]
}
