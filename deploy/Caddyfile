# Beava public demo — TLS + reverse-proxy in front of the HTTP management API on 127.0.0.1:6401.
# The `demo.beava.dev` placeholder is rewritten by deploy/provision.sh to the real domain.
#
# Defense in depth:
#   1. `--tcp-bind 127.0.0.1` in beava.service keeps the raw TCP protocol (port 6400) off the public iface.
#   2. `ufw deny 6400/tcp, 6401/tcp` in provision.sh blocks any stray binds at the kernel.
#   3. The admin middleware in src/server/auth.rs requires loopback or bearer token.
#   4. This Caddyfile additionally 404s admin paths at the edge so scanners can't even probe.

demo.beava.dev {
	encode gzip

	header {
		Strict-Transport-Security "max-age=31536000"
		X-Content-Type-Options "nosniff"
		Referrer-Policy "strict-origin-when-cross-origin"
		# CORS on public read endpoints — allows blog/external embeds.
		Access-Control-Allow-Origin "*"
	}

	# Rate limiting. Requires the caddy-ratelimit module. If the default caddy apt
	# package does NOT ship the module, comment this block out — smoke invariants
	# still pass and the launch-window blast radius is small. Document trade-off in
	# deploy/README.md.
	#
	# rate_limit {
	#     zone public_zone {
	#         key {remote_host}
	#         events 120
	#         window 1m
	#     }
	# }

	# Block admin paths at the edge. The middleware already enforces this server-side
	# (403 from non-loopback without bearer), but 404 at the edge avoids leaking that
	# the routes exist. Belt + suspenders.
	@admin path /pipelines* /snapshot* /debug/* /debug*
	handle @admin {
		respond "Not found" 404
	}

	# Everything else forwards to the Beava HTTP management API on loopback:
	#   /           — demo page (served in --public-mode)
	#   /health     — liveness probe
	#   /metrics    — Prometheus aggregates
	#   /public/*   — read-only public surface (features / recent-events / stats)
	#   /static/*   — embedded UI assets
	reverse_proxy 127.0.0.1:6401 {
		# Strip any Authorization header arriving from the public internet so that
		# an attacker cannot attempt to smuggle a bearer token through the proxy to
		# admin routes. Loopback access from `ssh -L 6401:127.0.0.1:6401 demo-vm`
		# bypasses Caddy entirely and keeps admin UX intact.
		header_up -Authorization
	}
}
